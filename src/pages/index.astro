---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				position: relative;
				min-height: 80vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 6em 1em 4em;
			}
			.hero-content {
				position: relative;
				z-index: 1;
				animation: fadeInUp 0.8s ease;
			}
			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 6px 18px;
				border-radius: 999px;
				border: 1px solid var(--card-border);
				background: var(--card-bg);
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.hero-badge-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: #00cec9;
				animation: pulse 2s ease-in-out infinite;
			}
			@keyframes pulse {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.3; }
			}
			.hero h1 {
				font-size: clamp(3rem, 8vw, 5rem);
				font-weight: 800;
				line-height: 1.1;
				letter-spacing: -2px;
				margin-bottom: 0.3em;
			}
			.hero h1 span {
				background: var(--gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.2em;
				margin-bottom: 2.5em;
				max-width: 500px;
				margin-left: auto;
				margin-right: auto;
			}
			.hero-links {
				display: flex;
				gap: 1em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 14px 32px;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95rem;
				transition: transform var(--transition), box-shadow var(--transition);
				border: none;
				cursor: pointer;
			}
			.btn:hover {
				transform: translateY(-2px);
			}
			.btn-primary {
				background: var(--gradient);
				color: #fff;
				box-shadow: 0 4px 20px rgba(108, 92, 231, 0.3);
			}
			.btn-primary:hover {
				box-shadow: 0 8px 30px rgba(108, 92, 231, 0.45);
				color: #fff;
			}
			.btn-secondary {
				background: var(--card-bg);
				color: rgb(var(--black));
				border: 1px solid var(--card-border);
			}
			.btn-secondary:hover {
				border-color: rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.05);
			}

			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(30px); }
				to { opacity: 1; transform: translateY(0); }
			}

			.features-section {
				padding: 4em 0;
			}
			.section-header {
				text-align: center;
				margin-bottom: 3em;
			}
			.section-label {
				font-size: 0.8rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 2px;
				color: var(--accent);
				margin-bottom: 12px;
			}
			.section-title {
				font-size: clamp(1.8rem, 4vw, 2.5rem);
				font-weight: 700;
				letter-spacing: -1px;
				margin-bottom: 12px;
			}
			.section-desc {
				color: rgb(var(--gray));
				font-size: 1.05rem;
				max-width: 500px;
				margin: 0 auto;
			}
			.features {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}
			.feature-card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: var(--radius);
				padding: 2em 1.5em;
				transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
				position: relative;
				overflow: hidden;
			}
			.feature-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: var(--gradient);
				opacity: 0;
				transition: opacity var(--transition);
			}
			.feature-card:hover::before { opacity: 1; }
			.feature-card:hover {
				transform: translateY(-6px);
				border-color: rgba(255, 255, 255, 0.12);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
			}
			.feature-icon {
				width: 48px;
				height: 48px;
				border-radius: 12px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.4rem;
				margin-bottom: 20px;
			}
			.fi-1 { background: rgba(108, 92, 231, 0.15); color: #6c5ce7; }
			.fi-2 { background: rgba(0, 206, 201, 0.15); color: #00cec9; }
			.fi-3 { background: rgba(253, 121, 168, 0.15); color: #fd79a8; }
			.feature-card h3 {
				margin: 0 0 0.5em 0;
				font-size: 1.1em;
				font-weight: 600;
			}
			.feature-card p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
				line-height: 1.7;
			}

			/* Stats section */
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
				margin-top: 3em;
			}
			.stat-card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: var(--radius);
				padding: 2em 1.5em;
				text-align: center;
				transition: transform var(--transition), border-color var(--transition);
			}
			.stat-card:hover {
				transform: translateY(-4px);
				border-color: rgba(255, 255, 255, 0.12);
			}
			.stat-number {
				font-size: 2rem;
				font-weight: 800;
				letter-spacing: -1px;
				background: var(--gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.stat-label {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-top: 4px;
			}

			@media (max-width: 720px) {
				.features {
					grid-template-columns: 1fr;
				}
				.stats-grid {
					grid-template-columns: 1fr;
				}
				.hero {
					min-height: 60vh;
				}
			}
		</style>
	</head>
	<body>
		<!-- Background Orbs -->
		<div class="bg-orb bg-orb--1"></div>
		<div class="bg-orb bg-orb--2"></div>
		<div class="bg-orb bg-orb--3"></div>

		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<div class="hero-badge">
						<span class="hero-badge-dot"></span>
						欢迎来到流光镜影
					</div>
					<h1>用 <span>光影</span> 记录<br>科研的瞬间</h1>
					<p>记录生物信息学研究、学习笔记与生活感悟的个人博客</p>
					<div class="hero-links">
						<a href="/blog" class="btn btn-primary">阅读博客</a>
						<a href="/about" class="btn btn-secondary">了解更多</a>
					</div>
				</div>
			</section>

			<section class="features-section">
				<div class="section-header reveal">
					<div class="section-label">核心内容</div>
					<h2 class="section-title">探索与记录</h2>
					<p class="section-desc">涵盖生物信息学、学习笔记与研究思考</p>
				</div>
				<div class="features">
					<div class="feature-card reveal">
						<div class="feature-icon fi-1">🔬</div>
						<h3>生物信息学</h3>
						<p>宏基因组、基因组注释、比较基因组学等分析流程与笔记</p>
					</div>
					<div class="feature-card reveal">
						<div class="feature-icon fi-2">📝</div>
						<h3>学习笔记</h3>
						<p>工具使用、编程技巧、数据分析方法的记录与总结</p>
					</div>
					<div class="feature-card reveal">
						<div class="feature-icon fi-3">💡</div>
						<h3>研究思考</h3>
						<p>科研过程中的想法、经验与心得分享</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

			document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
		</script>
	</body>
</html>
