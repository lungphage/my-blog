---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const articles = [
	{ title: '真菌 MAG 注释流程 — funannotate', date: '2026-05-21', url: '/fungal_mag_funannotate.html', icon: '🍄', category: '软件安装' },
	{ title: '批判性问题 | HUNT肠道菌群GWAS研究', date: '2026-05-21', url: '/HUNT_microbiota_critical_questions_claude.html', icon: '❓', category: '文献阅读' },
	{ title: 'HUNT 研究：宿主遗传因素与肠道微生物组成', date: '2026-05-21', url: '/HUNT_microbiota_summary_deepseek.html', icon: '📖', category: '文献阅读' },
	{ title: 'Funannotate Singularity 完整操作记录', date: '2026-05-21', url: '/funannotate_final_guide.html', icon: '📋', category: '软件安装' },
	{ title: '上传过程记录', date: '2026-05-21', url: '/upload_process.html', icon: '📝', category: '奇思妙想' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 - ${SITE_TITLE}`} description="所有文章按时间排列" />
		<style>
			main { width: var(--main-width); }
			.page-title { margin-bottom: 0.3em; }
			.page-subtitle { color: rgb(var(--gray)); margin-bottom: 2em; font-size: 1.05em; }
			.timeline { position: relative; padding-left: 2em; }
			.timeline::before {
				content: '';
				position: absolute;
				left: 7px;
				top: 0;
				bottom: 0;
				width: 2px;
				background: var(--card-border);
			}
			.timeline-item {
				position: relative;
				margin-bottom: 1.5em;
				padding-left: 1.5em;
			}
			.timeline-item::before {
				content: '';
				position: absolute;
				left: -1.5em;
				top: 0.6em;
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: var(--accent);
				border: 2px solid var(--body-bg);
			}
			.timeline-date {
				font-size: 0.82em;
				color: rgb(var(--gray));
				margin-bottom: 0.2em;
			}
			.timeline-card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 14px 18px;
				transition: transform 0.2s, background 0.3s, border-color 0.3s;
			}
			.timeline-card:hover { transform: translateX(4px); }
			.timeline-card a {
				text-decoration: none !important;
				color: inherit;
				display: flex;
				align-items: center;
				gap: 10px;
			}
			.timeline-card .icon { font-size: 1.3em; }
			.timeline-card .title { font-weight: 600; color: rgb(var(--black)); }
			.timeline-card .cat {
				font-size: 0.76em;
				padding: 2px 8px;
				border-radius: 8px;
				background: var(--accent-light);
				color: var(--accent-dark);
				margin-left: auto;
				white-space: nowrap;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">📚 归档</h1>
			<p class="page-subtitle">共 {articles.length} 篇文章</p>
			<div class="timeline">
				{articles.map((a) => (
					<div class="timeline-item">
						<div class="timeline-date">{a.date}</div>
						<div class="timeline-card">
							<a href={a.url}>
								<span class="icon">{a.icon}</span>
								<span class="title">{a.title}</span>
								<span class="cat">{a.category}</span>
							</a>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
