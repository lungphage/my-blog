---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import Giscus from '../../../components/Giscus.astro';
import { SITE_TITLE } from '../../../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客评论 - ${SITE_TITLE}`} description="对博客的想法和建议，欢迎留言讨论" />
		<style>
			main { width: var(--main-width); }
			.page-title { margin-bottom: 0.3em; }
			.page-subtitle { color: rgb(var(--gray)); margin-bottom: 2em; font-size: 1.05em; }
			.comment-section {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 14px;
				padding: 2em;
				transition: background 0.3s, border-color 0.3s;
			}
			.comment-section h2 {
				margin: 0 0 0.5em 0;
				font-size: 1.3em;
				color: rgb(var(--black));
			}
			.comment-section p {
				color: rgb(var(--gray));
				margin-bottom: 1em;
				line-height: 1.8;
			}
			.info-box {
				background: var(--accent-light);
				border-left: 4px solid var(--accent);
				padding: 12px 16px;
				border-radius: 6px;
				margin-bottom: 1.5em;
				font-size: 0.92em;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">💬 博客评论</h1>
			<p class="page-subtitle">对博客的想法和建议，欢迎留言讨论</p>

			<div class="comment-section">
				<h2>留言板</h2>
				<p>欢迎对博客内容、排版、功能等方面提出建议和意见。你的每一条评论我都会认真阅读。</p>
				<div class="info-box">
					<strong>💡 提示：</strong>评论需要 GitHub 账号登录。评论后我会收到 GitHub 通知，会尽快回复。
				</div>
				<Giscus id="blog-comments" />
			</div>
		</main>
		<Footer />
	</body>
</html>
