---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 4em 0 2em;
			}
			.hero h1 {
				font-size: 2.8em;
				margin-bottom: 0.3em;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.2em;
				margin-bottom: 2em;
			}
			.hero-links {
				display: flex;
				gap: 1em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-block;
				padding: 0.8em 2em;
				border-radius: 8px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1em;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.btn:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.btn-primary {
				background: var(--accent);
				color: #fff;
			}
			.btn-secondary {
				background: var(--card-bg);
				color: rgb(var(--black));
				border: 1px solid var(--card-border);
			}
			.features {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
				gap: 1.5em;
				margin-top: 3em;
			}
			.feature-card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				padding: 1.5em;
				transition: background 0.3s, border-color 0.3s;
			}
			.feature-card h3 {
				margin: 0 0 0.5em 0;
				font-size: 1.1em;
			}
			.feature-card p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>流光镜影</h1>
				<p>记录光影与瞬间的故事</p>
				<div class="hero-links">
					<a href="/blog" class="btn btn-primary">阅读博客</a>
					<a href="/about" class="btn btn-secondary">了解更多</a>
				</div>
			</div>
			<div class="features">
				<div class="feature-card">
					<h3>🔬 生物信息学</h3>
					<p>宏基因组、基因组注释、比较基因组学等分析流程与笔记</p>
				</div>
				<div class="feature-card">
					<h3>📝 学习笔记</h3>
					<p>工具使用、编程技巧、数据分析方法的记录与总结</p>
				</div>
				<div class="feature-card">
					<h3>💡 研究思考</h3>
					<p>科研过程中的想法、经验与心得分享</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
