---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const categories = [
	{ id: 'all', label: '全部' },
	{ id: 'software', label: '软件安装' },
	{ id: 'paper', label: '文献阅读' },
	{ id: 'life', label: '生活点滴' },
	{ id: 'thoughts', label: '奇思妙想' },
	{ id: 'review', label: '博客评论' },
];

const articles = [
	{
		title: '真菌 MAG 注释流程 — funannotate',
		desc: '基于 funannotate v1.8.17 + Singularity 容器环境，适用于宏基因组 Binning 后真菌 MAG 的完整注释流程',
		date: '2026年5月21日',
		url: '/fungal_mag_funannotate.html',
		icon: '🍄',
		category: 'software',
		tags: ['funannotate', '真菌', 'MAG', '宏基因组', 'Singularity'],
	},
	{
		title: '批判性问题 | HUNT肠道菌群GWAS研究',
		desc: '对 HUNT 队列肠道菌群 GWAS 研究的批判性分析与关键问题梳理',
		date: '2026年5月21日',
		url: '/HUNT_microbiota_critical_questions_claude.html',
		icon: '❓',
		category: 'paper',
		tags: ['HUNT', 'GWAS', '肠道菌群', '文献批判'],
	},
	{
		title: 'HUNT 研究：宿主遗传因素与肠道微生物组成 — 论文详细总结',
		desc: 'HUNT 研究中宿主遗传因素对肠道微生物组影响的详细论文总结',
		date: '2026年5月21日',
		url: '/HUNT_microbiota_summary_deepseek.html',
		icon: '📖',
		category: 'paper',
		tags: ['HUNT', '肠道菌群', '遗传学', '论文总结'],
	},
	{
		title: 'Funannotate Singularity 完整操作记录 — Fungus_sp_MAG1',
		desc: 'funannotate 完整操作流程记录，从 clean 到 annotate 全步骤实战',
		date: '2026年5月21日',
		url: '/funannotate_final_guide.html',
		icon: '📋',
		category: 'software',
		tags: ['funannotate', '真菌', '操作记录', 'Singularity'],
	},
	{
		title: '上传过程记录 — funannotate_final_guide.html',
		desc: '记录如何将 HTML 文章添加到流光镜影博客的完整步骤与代码',
		date: '2026年5月21日',
		url: '/upload_process.html',
		icon: '📝',
		category: 'thoughts',
		tags: ['博客', '教程', 'Astro'],
	},
	{
		title: '生活点滴',
		desc: '记录日常生活，支持评论和图片分享',
		date: '2026年5月21日',
		url: '/blog/life/',
		icon: '🌿',
		category: 'life',
		tags: ['生活', '日常', '分享'],
	},
	{
		title: '博客评论',
		desc: '对博客的想法和建议，欢迎留言讨论',
		date: '2026年5月21日',
		url: '/blog/comments/',
		icon: '💬',
		category: 'review',
		tags: ['评论', '反馈', '建议'],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: var(--main-width);
			}
			.page-header {
				text-align: center;
				padding: 3em 0 2em;
			}
			.page-title {
				font-size: clamp(2rem, 5vw, 3rem);
				margin-bottom: 0.3em;
				background: var(--gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.page-subtitle {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 1.05em;
			}
			.search-box {
				margin-bottom: 1.5em;
			}
			.search-box input {
				width: 100%;
				padding: 14px 20px;
				border-radius: var(--radius);
				border: 1px solid var(--card-border);
				background: var(--card-bg);
				color: rgb(var(--gray-dark));
				font-size: 0.95em;
				transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
				box-sizing: border-box;
			}
			.search-box input:focus {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px var(--accent-light);
			}
			.search-box input::placeholder {
				color: rgb(var(--gray));
			}
			.tabs {
				display: flex;
				gap: 8px;
				margin-bottom: 2em;
				flex-wrap: wrap;
			}
			.tab {
				padding: 10px 22px;
				border-radius: 999px;
				border: 1px solid var(--card-border);
				background: var(--card-bg);
				color: rgb(var(--gray-dark));
				cursor: pointer;
				font-size: 0.9rem;
				font-weight: 600;
				transition: all var(--transition);
				text-decoration: none;
			}
			.tab:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.tab.active {
				background: var(--gradient);
				color: #fff;
				border-color: transparent;
				box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);
			}
			.blog-list {
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.blog-card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: var(--radius);
				overflow: hidden;
				transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
				position: relative;
			}
			.blog-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: var(--gradient);
				opacity: 0;
				transition: opacity var(--transition);
			}
			.blog-card:hover::before { opacity: 1; }
			.blog-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
				border-color: rgba(255, 255, 255, 0.1);
			}
			.blog-card a {
				display: flex;
				align-items: center;
				text-decoration: none !important;
				color: inherit;
				padding: 1.5rem;
				gap: 1.5rem;
			}
			.card-icon {
				font-size: 2em;
				width: 56px;
				height: 56px;
				line-height: 56px;
				text-align: center;
				background: var(--accent-light);
				border-radius: 14px;
				flex-shrink: 0;
				transition: transform var(--transition);
			}
			.blog-card:hover .card-icon {
				transform: scale(1.05);
			}
			.card-content {
				flex: 1;
				min-width: 0;
			}
			.card-content h3 {
				margin: 0 0 0.4rem 0;
				font-size: 1.1em;
				color: rgb(var(--black));
				font-weight: 600;
			}
			.card-meta {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-bottom: 0.5rem;
			}
			.card-date {
				color: rgb(var(--gray));
				font-size: 0.82em;
			}
			.card-badge {
				display: inline-block;
				padding: 3px 12px;
				border-radius: 999px;
				font-size: 0.72em;
				font-weight: 600;
				background: var(--accent-light);
				color: var(--accent);
			}
			.card-desc {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.88em;
				line-height: 1.6;
				overflow: hidden;
				text-overflow: ellipsis;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
			}
			.card-tags {
				display: flex;
				gap: 6px;
				flex-wrap: wrap;
				margin-top: 10px;
			}
			.card-tag {
				font-size: 0.75em;
				color: var(--accent);
				background: var(--accent-light);
				padding: 3px 10px;
				border-radius: 999px;
				cursor: pointer;
				transition: all var(--transition);
			}
			.card-tag:hover {
				background: var(--accent);
				color: #fff;
			}
			.card-tag.active-tag {
				background: var(--accent);
				color: #fff;
			}

			/* Scroll reveal */
			.blog-card {
				opacity: 0;
				transform: translateY(20px);
				transition: opacity 0.6s ease, transform 0.6s ease, box-shadow var(--transition), border-color var(--transition);
			}
			.blog-card.visible {
				opacity: 1;
				transform: translateY(0);
			}

			@media (max-width: 720px) {
				main {
					width: 100%;
				}
				.blog-card a {
					flex-direction: column;
					text-align: center;
				}
				.card-meta {
					justify-content: center;
				}
				.card-tags {
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<!-- Background Orbs -->
		<div class="bg-orb bg-orb--1"></div>
		<div class="bg-orb bg-orb--2"></div>
		<div class="bg-orb bg-orb--3"></div>

		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">博客</h1>
				<p class="page-subtitle">记录学习与研究的点滴</p>
			</div>
			<div class="search-box">
				<input type="text" id="blog-search" placeholder="搜索文章标题、描述..." />
			</div>
			<div class="tabs">
				{categories.map((cat) => (
					<button class={`tab${cat.id === 'all' ? ' active' : ''}`} data-category={cat.id}>
						{cat.label}
					</button>
				))}
			</div>
			<ul class="blog-list">
				{articles.map((article) => (
					<li class="blog-card" data-category={article.category} data-tags={article.tags?.join(',')}>
						<a href={article.url}>
							<div class="card-icon">{article.icon}</div>
							<div class="card-content">
								<h3>{article.title}</h3>
								<div class="card-meta">
									<span class="card-date">{article.date}</span>
									<span class="card-badge">
										{article.category === 'software' ? '软件安装' : article.category === 'paper' ? '文献阅读' : article.category === 'life' ? '生活点滴' : article.category === 'review' ? '博客评论' : '奇思妙想'}
									</span>
								</div>
								<p class="card-desc">{article.desc}</p>
								{article.tags && (
									<div class="card-tags">
										{article.tags.map((tag) => (
											<span class="card-tag">#{tag}</span>
										))}
									</div>
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<script>
			let activeCategory = 'all';
			let activeTag = '';

			function filterCards() {
				const query = (document.getElementById('blog-search') as HTMLInputElement).value.toLowerCase();
				document.querySelectorAll('.blog-card').forEach((card) => {
					const cat = card.getAttribute('data-category');
					const tags = card.getAttribute('data-tags') || '';
					const text = (card.textContent || '').toLowerCase();
					const catMatch = activeCategory === 'all' || cat === activeCategory;
					const tagMatch = !activeTag || tags.split(',').includes(activeTag);
					const searchMatch = !query || text.includes(query);
					(card as HTMLElement).style.display = catMatch && tagMatch && searchMatch ? '' : 'none';
				});
			}

			document.querySelectorAll('.tab').forEach((tab) => {
				tab.addEventListener('click', () => {
					document.querySelectorAll('.tab').forEach((t) => t.classList.remove('active'));
					tab.classList.add('active');
					activeCategory = tab.getAttribute('data-category') || 'all';
					activeTag = '';
					filterCards();
				});
			});

			document.getElementById('blog-search')?.addEventListener('input', filterCards);

			document.addEventListener('click', (e) => {
				const tag = (e.target as HTMLElement).closest('.card-tag');
				if (!tag) return;
				e.preventDefault();
				e.stopPropagation();
				const tagText = tag.textContent?.replace('#', '').trim() || '';
				if (activeTag === tagText) {
					activeTag = '';
				} else {
					activeTag = tagText;
				}
				document.querySelectorAll('.card-tag').forEach(t => {
					t.classList.toggle('active-tag', t.textContent?.replace('#', '').trim() === activeTag && activeTag);
				});
				filterCards();
			});

			// Scroll reveal animation
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry, index) => {
					if (entry.isIntersecting) {
						setTimeout(() => {
							entry.target.classList.add('visible');
						}, index * 100);
					}
				});
			}, { threshold: 0.1 });

			document.querySelectorAll('.blog-card').forEach(card => observer.observe(card));
		</script>
	</body>
</html>
