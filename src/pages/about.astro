---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="关于我"
	description="流光镜影 - 关于作者"
	pubDate={new Date('2026-05-21')}
>
	<div class="about-hero">
		<div class="avatar">🔬</div>
		<h2>流光镜影</h2>
		<p class="bio">江西农业大学 · 生物信息学</p>
	</div>

	<div class="links-grid">
		<a href="https://space.bilibili.com/5950502" target="_blank" class="link-block">
			<span class="link-icon">📺</span>
			<span class="link-name">B站</span>
		</a>
		<a href="https://github.com/lungphage" target="_blank" class="link-block">
			<span class="link-icon">💻</span>
			<span class="link-name">GitHub</span>
		</a>
		<a href="https://chat.openai.com" target="_blank" class="link-block">
			<span class="link-icon">🤖</span>
			<span class="link-name">ChatGPT</span>
		</a>
		<a href="https://gemini.google.com" target="_blank" class="link-block">
			<span class="link-icon">✨</span>
			<span class="link-name">Gemini</span>
		</a>
		<a href="https://www.jxau.edu.cn/" target="_blank" class="link-block">
			<span class="link-icon">🎓</span>
			<span class="link-name">江西农业大学</span>
		</a>
	</div>
</Layout>

<style>
	.about-hero {
		text-align: center;
		padding: 2em 0 2em;
	}
	.avatar {
		font-size: 3em;
		width: 80px;
		height: 80px;
		line-height: 80px;
		margin: 0 auto 0.8em;
		background: var(--gradient);
		border-radius: 20px;
		transition: transform var(--transition), box-shadow var(--transition);
	}
	.avatar:hover {
		transform: scale(1.05);
		box-shadow: 0 8px 30px rgba(108, 92, 231, 0.4);
	}
	.about-hero h2 {
		margin: 0 0 0.3em;
		font-size: 1.8em;
		font-weight: 700;
	}
	.bio {
		color: rgb(var(--gray));
		margin: 0;
		font-size: 0.95em;
	}
	.links-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 16px;
		max-width: 520px;
		margin: 0 auto;
	}
	.link-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 28px 16px;
		border-radius: var(--radius);
		text-decoration: none !important;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		color: rgb(var(--black));
		transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background var(--transition);
		position: relative;
		overflow: hidden;
	}
	.link-block::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--gradient);
		opacity: 0;
		transition: opacity var(--transition);
	}
	.link-block:hover::before { opacity: 1; }
	.link-block:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
		border-color: rgba(255, 255, 255, 0.1);
	}
	.link-block:active {
		transform: scale(0.97);
	}
	.link-icon {
		font-size: 1.8em;
	}
	.link-name {
		font-weight: 600;
		font-size: 0.9em;
		text-align: center;
		line-height: 1.3;
	}
</style>
