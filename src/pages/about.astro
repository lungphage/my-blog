---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="关于我"
	description="流光镜影 - 关于作者"
	pubDate={new Date('2026-05-21')}
>
	<div class="about-hero">
		<div class="avatar">🔬</div>
		<h2>流光镜影</h2>
		<p class="bio">江西农业大学 · 生物信息学</p>
	</div>

	<div class="links-grid">
		<a href="https://space.bilibili.com/5950502" target="_blank" class="link-block">
			<span class="link-icon">📺</span>
			<span class="link-name">B站</span>
		</a>
		<a href="https://github.com/lungphage" target="_blank" class="link-block">
			<span class="link-icon">💻</span>
			<span class="link-name">GitHub</span>
		</a>
		<a href="https://chat.openai.com" target="_blank" class="link-block">
			<span class="link-icon">🤖</span>
			<span class="link-name">ChatGPT</span>
		</a>
		<a href="https://gemini.google.com" target="_blank" class="link-block">
			<span class="link-icon">✨</span>
			<span class="link-name">Gemini</span>
		</a>
		<a href="https://www.jxau.edu.cn/" target="_blank" class="link-block">
			<span class="link-icon">🎓</span>
			<span class="link-name">江西农业大学</span>
		</a>
	</div>
</Layout>

<style>
	.about-hero {
		text-align: center;
		padding: 2em 0 2em;
	}
	.avatar {
		font-size: 3em;
		width: 80px;
		height: 80px;
		line-height: 80px;
		margin: 0 auto 0.6em;
		background: linear-gradient(135deg, #805ad5, #553c9a);
		border-radius: 16px;
	}
	.about-hero h2 {
		margin: 0 0 0.2em;
		font-size: 1.6em;
	}
	.bio {
		color: rgb(var(--gray));
		margin: 0;
		font-size: 0.95em;
	}
	.links-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 16px;
		max-width: 520px;
		margin: 0 auto;
	}
	.link-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 28px 16px;
		border-radius: 14px;
		text-decoration: none !important;
		background: linear-gradient(135deg, #805ad5 0%, #6b46c1 100%);
		color: #fff;
		transition: transform 0.25s, box-shadow 0.25s, background 0.3s;
	}
	.link-block:hover {
		transform: translateY(-4px) scale(1.03);
		box-shadow: 0 8px 24px rgba(128, 90, 213, 0.4);
		background: linear-gradient(135deg, #6b46c1 0%, #553c9a 100%);
		color: #fff;
	}
	.link-block:active {
		transform: scale(0.97);
	}
	.link-icon {
		font-size: 1.8em;
	}
	.link-name {
		font-weight: 600;
		font-size: 0.9em;
		text-align: center;
		line-height: 1.3;
	}
</style>
