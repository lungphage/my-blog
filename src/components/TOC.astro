---

<nav class="toc" id="toc">
	<div class="toc-title">📑 目录</div>
	<div class="toc-list" id="toc-list"></div>
</nav>

<script>
	function buildTOC() {
		const article = document.querySelector('.prose') || document.querySelector('article') || document.querySelector('main');
		if (!article) return;
		const headings = article.querySelectorAll('h2, h3');
		if (headings.length < 2) {
			document.getElementById('toc')?.classList.add('hidden');
			return;
		}
		const list = document.getElementById('toc-list')!;
		list.innerHTML = '';
		headings.forEach((h, i) => {
			if (!h.id) h.id = 'heading-' + i;
			const a = document.createElement('a');
			a.href = '#' + h.id;
			a.textContent = h.textContent || '';
			a.className = h.tagName === 'H3' ? 'toc-link toc-h3' : 'toc-link';
			a.addEventListener('click', (e) => {
				e.preventDefault();
				document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth' });
			});
			list.appendChild(a);
		});

		// Highlight active section
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					list.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
					const active = list.querySelector(`a[href="#${entry.target.id}"]`);
					active?.classList.add('active');
				}
			});
		}, { rootMargin: '-20% 0px -70% 0px' });
		headings.forEach(h => observer.observe(h));
	}

	buildTOC();
</script>

<style>
	.toc {
		position: sticky;
		top: 80px;
		max-height: calc(100vh - 120px);
		overflow-y: auto;
		padding: 16px 20px;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 12px;
		margin-bottom: 2em;
		transition: background 0.3s, border-color 0.3s;
	}
	.toc.hidden { display: none; }
	.toc-title {
		font-weight: 700;
		font-size: 0.92em;
		color: rgb(var(--black));
		margin-bottom: 10px;
	}
	.toc-list {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.toc-link {
		display: block;
		padding: 5px 10px;
		font-size: 0.85em;
		color: rgb(var(--gray));
		text-decoration: none !important;
		border-left: 2px solid transparent;
		border-radius: 4px;
		transition: all 0.2s;
		line-height: 1.4;
	}
	.toc-link:hover { color: var(--accent); background: var(--accent-light); }
	.toc-link.active { color: var(--accent); border-left-color: var(--accent); font-weight: 600; }
	.toc-h3 { padding-left: 24px; font-size: 0.82em; }

	@media (max-width: 1100px) {
		.toc { position: static; max-height: none; }
	}
</style>
